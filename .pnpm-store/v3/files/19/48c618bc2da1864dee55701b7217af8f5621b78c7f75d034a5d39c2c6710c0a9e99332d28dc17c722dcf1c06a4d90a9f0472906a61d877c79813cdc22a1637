const getSuggestionProps = (editor, node, { id = nanoid(), createdAt = Date.now(), suggestionDeletion, suggestionUpdate, transient } = {}) => {
	const type = suggestionDeletion ? "remove" : suggestionUpdate ? "update" : "insert";
